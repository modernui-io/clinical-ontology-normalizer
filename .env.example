# Clinical Ontology Normalizer - Environment Configuration
# Copy to .env and fill in values, or run: bash scripts/generate_env.sh
#
# IMPORTANT: Never commit .env to git. Only .env.example is tracked.

# =============================================================================
# REQUIRED: Database Credentials
# Generate secure values with: openssl rand -base64 32
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=           # REQUIRED - generate: openssl rand -base64 32
POSTGRES_DB=clinical_ontology

# =============================================================================
# REQUIRED: Redis
# =============================================================================
REDIS_PASSWORD=              # REQUIRED - generate: openssl rand -base64 32

# =============================================================================
# REQUIRED: Neo4j Graph Database
# =============================================================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=              # REQUIRED - generate: openssl rand -base64 32

# =============================================================================
# Authentication
# =============================================================================
API_KEY=                     # Generate: openssl rand -hex 32
JWT_SECRET_KEY=              # Generate: openssl rand -base64 64
AUTH_ENABLED=false           # Set true for production
AUTH_BYPASS_DEV=false        # Set true only for local development

# =============================================================================
# Application
# =============================================================================
DEBUG=false
ENVIRONMENT=development      # development, staging, production

# =============================================================================
# Kafka Message Broker
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# =============================================================================
# Optional: External Services
# =============================================================================
# ANTHROPIC_API_KEY=
# UMLS_API_KEY=
# METRIPORT_API_KEY=
# METRIPORT_WEBHOOK_KEY=

# =============================================================================
# Optional: Monitoring & Observability
# =============================================================================
# SENTRY_DSN=
# PROMETHEUS_ENABLED=false
# JAEGER_ENDPOINT=
