# Clinical Ontology Normalizer - Environment Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clinical_ontology
# Note: Default port is 5432 in docker-compose.yml

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379
# Note: Default port is 6379 in docker-compose.yml

# =============================================================================
# Neo4j Graph Database
# =============================================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
# Web interface: http://localhost:7474
# Bolt protocol: bolt://localhost:7687

# =============================================================================
# Kafka Message Broker
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Zookeeper: localhost:2181
# External access: localhost:29092

# =============================================================================
# Backend API
# =============================================================================
BACKEND_PORT=8000
DEBUG=false
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/clinical_ontology

# Authentication (set AUTH_ENABLED=true for production)
AUTH_ENABLED=false
API_KEY=dev-api-key-change-in-production

# Comma-separated list of valid API keys (for production)
CON_API_KEYS=

# Vocabulary settings
USE_DB_VOCABULARY=true

# Tenant-patient isolation (optional)
# Format: CON_TENANT_<KEY>_PATIENTS=P001,P002
# Example: CON_TENANT_KEY1_PATIENTS=P001,P002,P003

# =============================================================================
# Frontend
# =============================================================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://backend:8000

# =============================================================================
# Production Settings (uncomment for production)
# =============================================================================
# POSTGRES_PASSWORD=<strong-password>
# NEO4J_PASSWORD=<strong-password>
# AUTH_ENABLED=true
# CON_API_KEYS=key1,key2,key3
# DEBUG=false

# =============================================================================
# Optional: External Services
# =============================================================================
# LLM_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# =============================================================================
# Optional: Monitoring & Observability
# =============================================================================
# SENTRY_DSN=
# PROMETHEUS_ENABLED=false
# JAEGER_ENDPOINT=
