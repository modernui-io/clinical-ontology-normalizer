{
  "metadata": {
    "name": "nlp-extraction-gold",
    "domain": "nlp_extraction",
    "description": "Gold standard dataset for NLP mention extraction evaluation. 50 annotated clinical sentences covering conditions, medications, procedures, labs, and assertion types.",
