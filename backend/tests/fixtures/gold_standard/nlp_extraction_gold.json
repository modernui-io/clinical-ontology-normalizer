    "sentence_count": 50,
    "domains_covered": ["CONDITION", "MEDICATION", "PROCEDURE", "LAB"],
    "assertion_types": ["PRESENT", "ABSENT", "HYPOTHETICAL", "FAMILY_HISTORY", "POSSIBLE"]
  },
